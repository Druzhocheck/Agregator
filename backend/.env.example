# Polymarket Relayer & Builder API (для deploy proxy без захода на polymarket.com)
# См. backend/README.md — раздел «Переменные окружения»

# URL релейера Polymarket (публичный, один для всех)
RELAYER_URL=https://relayer-v2.polymarket.com/

# Учётные данные Builder Program — создаются в настройках Polymarket (см. инструкцию в README)
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# Опционально: свои хосты (по умолчанию — production)
# CLOB_HOST=https://clob.polymarket.com
# GAMMA_HOST=https://gamma-api.polymarket.com
# PORT=3001
